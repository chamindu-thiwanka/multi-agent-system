# ================================================================
# MULTI-AGENT SYSTEM — Environment Variables Template
# ================================================================
#
# HOW TO USE THIS FILE:
# 1. Copy this file: copy .env.example .env    (run in terminal)
# 2. Open .env and fill in your real values
# 3. Never commit .env to Git
#
# This file (.env.example) goes to GitHub as documentation.
# It shows what variables are needed without exposing real values.
# ================================================================


# ================================================================
# LLM CONFIGURATION
# ================================================================
#
# This section controls WHICH AI model answers questions.
# This is how we achieve "model-agnostic design" — the requirement
# that says no hard-coded model dependency.
#
# HOW IT WORKS:
# config.py reads LLM_PROVIDER and LLM_MODEL_NAME
# It then creates the right LangChain LLM object
# All agent code just calls get_llm() — it doesn't know or care
# which model is actually running
#
# TO SWITCH MODELS:
# Change LLM_MODEL_NAME below. That's the ONLY change needed.
# No code changes required anywhere else.
#
# ── Ollama (local, free, your current setup) ──────────────────
# LLM_PROVIDER=ollama
# LLM_MODEL_NAME=llama3:latest       ← best reasoning
# LLM_MODEL_NAME=mistral:latest      ← faster, still good
# LLM_MODEL_NAME=qwen3:1.7b          ← fastest, less capable
#
# ── OpenAI (cloud, costs money, not needed now) ───────────────
# LLM_PROVIDER=openai
# LLM_MODEL_NAME=gpt-4o
#
# ── Anthropic (cloud, costs money, not needed now) ────────────
# LLM_PROVIDER=anthropic
# LLM_MODEL_NAME=claude-3-5-sonnet-20241022
# ─────────────────────────────────────────────────────────────

LLM_PROVIDER=ollama
LLM_MODEL_NAME=llama3:latest

# Base URL for Ollama API
# When running OUTSIDE Docker (direct Python): http://localhost:11434
# When running INSIDE Docker containers:       http://host.docker.internal:11434
#
# WHY THE DIFFERENCE?
# "localhost" inside a Docker container means the container itself
# not your laptop. "host.docker.internal" is a special Docker DNS
# name that means "the host machine running Docker" — your laptop.
# So Docker containers use host.docker.internal to reach Ollama
# which is running on your laptop, not inside Docker.
LLM_BASE_URL=http://localhost:11434

# Temperature controls how "creative" vs "deterministic" the LLM is
# 0.0 = always picks the most likely next word (deterministic, consistent)
# 1.0 = picks randomly from many options (creative, varied)
# For AI agents: use LOW temperature (0.0-0.2)
# WHY? Agents need to follow instructions precisely and reason logically
# Creativity is bad for agents — we want them to be predictable and accurate
LLM_TEMPERATURE=0.1


# ================================================================
# EMBEDDING MODEL CONFIGURATION
# ================================================================
#
# Embeddings are COMPLETELY DIFFERENT from the LLM above.
#
# LLM = reads text, GENERATES text ("Answer this question")
# Embedding model = reads text, outputs NUMBERS ("Convert to vector")
#
# We need embeddings for RAG (Retrieval-Augmented Generation):
# 1. During ingestion: convert documents → vectors → store in Chroma
# 2. During query: convert user question → vector → find similar docs
#
# nomic-embed-text is a dedicated embedding model. It's small (274MB)
# and specifically trained to create good semantic vectors.
# Using llama3 for embeddings would work but be slower and less accurate.

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL_NAME=nomic-embed-text

# Same URL logic as LLM_BASE_URL above
EMBEDDING_BASE_URL=http://localhost:11434


# ================================================================
# TAVILY INTERNET SEARCH API
# ================================================================
#
# Tavily provides AI-optimized web search results.
# Used by our Internet Search Agent.
#
# Why Tavily instead of Google Search API?
# - Google Search API costs $5 per 1000 queries
# - Tavily free tier = 1000 searches/month
# - Tavily specifically designed for AI agents
# - Returns clean, structured results (no HTML parsing needed)
# - Has a native LangChain integration
#
# Get your key at: https://tavily.com
# Free tier is more than enough for this project.

TAVILY_API_KEY=your_tavily_api_key_here


# ================================================================
# REDDIT API CREDENTIALS
# ================================================================
#
# Reddit API lets us search posts and comments programmatically.
# Used by our Reddit Intelligence Agent.
#
# Why Reddit?
# - Real user opinions (not SEO-optimized articles)
# - Current discussions (posts from today/this week)
# - Community sentiment on topics
# - Great for questions like "what do developers think about X?"
#
# How to get credentials:
# 1. Log in to Reddit at reddit.com
# 2. Go to: https://www.reddit.com/prefs/apps
# 3. Click "create another app..."
# 4. Name: multi-agent-system
# 5. Type: script (important — select this option)
# 6. Redirect URI: http://localhost:8080
# 7. Click "create app"
# 8. CLIENT_ID = the 14-character string under your app name
# 9. CLIENT_SECRET = the longer string labeled "secret"
#
# REDDIT_USER_AGENT format: appname/version by u/YourUsername
# Reddit requires this to identify your application

REDDIT_CLIENT_ID=your_14_char_client_id
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=multi-agent-system/1.0 by u/your_reddit_username


# ================================================================
# OPTIONAL CLOUD API KEYS
# ================================================================
#
# Leave these empty while using Ollama.
# Only fill them in if you change LLM_PROVIDER to openai/anthropic.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=


# ================================================================
# CHROMA VECTOR DATABASE SETTINGS
# ================================================================
#
# Chroma stores our document embeddings for RAG retrieval.
# It runs as a separate service (either local or in Docker).
#
# CHROMA_HOST:
# - "localhost" when running Python directly on your machine
# - "chroma" when running inside Docker (Docker service name)
#
# CHROMA_COLLECTION_NAME:
# A Chroma "collection" is like a table in a regular database.
# It groups related documents together.
# All our ingested documents go into the "knowledge_base" collection.

CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=knowledge_base


# ================================================================
# FASTAPI BACKEND SETTINGS
# ================================================================
#
# BACKEND_HOST=0.0.0.0 means "listen on ALL network interfaces"
# This is necessary for Docker — if you used 127.0.0.1 (localhost),
# the container would only accept connections from itself.
# 0.0.0.0 accepts connections from anywhere that can reach the container.

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000


# ================================================================
# MEMORY SETTINGS
# ================================================================
#
# Long-term memory is stored in a SQLite database file.
# SQLite = a simple database that lives in a single file (no server needed)
# Perfect for our use case — we don't need a full PostgreSQL setup.
#
# LONG_TERM_MEMORY_PATH = where to save the .db file
# MEMORY_LOOKBACK_COUNT = how many past conversations to include as context
# When you ask a new question, we load the last N conversation summaries
# so the agent has context about your previous interactions.

LONG_TERM_MEMORY_PATH=./memory_store.db
MEMORY_LOOKBACK_COUNT=5


# ================================================================
# LOGGING SETTINGS
# ================================================================
#
# Logging levels (from most to least verbose):
# DEBUG   → shows EVERYTHING: every function call, every variable
#            Use during development when debugging problems
# INFO    → shows normal operation: "Query received", "Tool called"
#            Use normally during development
# WARNING → only shows potential problems
# ERROR   → only shows actual errors
#
# We use INFO as default. Switch to DEBUG if something breaks
# and you need to see exactly what's happening.

LOG_LEVEL=INFO